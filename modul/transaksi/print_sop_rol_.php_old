<?php
// modul/transaksi/print_sop_rol.php
// Print SURAT PERINTAH KERJA ROL - Format A5 Portrait

if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

// PERBAIKAN: Path yang benar ke koneksi.php (2 level ke atas)
if (!isset($conn)) {
    include_once __DIR__ . '/../../koneksi.php';
}

// Cek apakah koneksi berhasil
if (!isset($conn) || !$conn) {
    die("Koneksi database gagal. Silakan periksa file koneksi.php");
}

$sop_id = isset($_GET['sop_id']) ? mysqli_real_escape_string($conn, $_GET['sop_id']) : '';
if (empty($sop_id)) {
    die("SOP ID tidak ditemukan");
}

// Ambil data header SOP
$head_query = mysqli_query($conn, "SELECT * FROM head_sop WHERE sop_id = '$sop_id' LIMIT 1");
if (!$head_query) {
    die("Query error: " . mysqli_error($conn));
}
$head = mysqli_fetch_assoc($head_query);

if (!$head) {
    die("Data SOP tidak ditemukan untuk ID: " . $sop_id);
}

// Ambil data detail SOP (spesifikasi Roll)
$detail_query = mysqli_query($conn, "SELECT * FROM det_sop WHERE sop_id = '$sop_id' LIMIT 1");
$detail = mysqli_fetch_assoc($detail_query);

// Format tanggal
$tgl_order = date('d-M-Y', strtotime($head['sop_date']));
$tgl_kirim = !empty($detail['shipment_due_date']) ? date('d-M-Y', strtotime($detail['shipment_due_date'])) : '-';

// Set header untuk print
header("Content-Type: text/html; charset=UTF-8");
?>
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>SURAT PERINTAH KERJA ROL - <?= $sop_id ?></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        @page {
            size: A5 portrait; /* DIUBAH kembali ke Portrait sesuai instruksi */
            margin: 5mm 7mm;
        }
        
        body {
            font-family: 'Courier New', 'Segoe UI', monospace;
            font-size: 8.5pt; /* Sedikit dikecilkan agar hemat space vertikal */
            background: white;
            color: #000;
            line-height: 1.2;
        }
        
        .print-container {
            max-width: 100%;
            margin: 0 auto;
        }
        
        /* Header */
        .header {
            text-align: center;
            margin-bottom: 5px;
            border-bottom: 1.5px solid #000;
            padding-bottom: 3px;
        }
        
        .header h1 {
            font-size: 13pt;
            font-weight: bold;
            letter-spacing: 1px;
        }
        
        .header .subtitle {
            font-size: 8pt;
        }
        
        /* Info Box / Spesifikasi */
        .info-box {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 2px;
            font-size: 8.5pt;
        }
        
        .info-box td {
            padding: 1px 3px;
            vertical-align: top;
            border: none;
        }
        
        .info-box td.label {
            width: 28%;
            font-weight: normal;
        }
        
        .info-box td.titik {
            width: 2%;
        }
        
        .info-box td.val {
            width: 70%;
            font-weight: bold;
        }
        
        /* Separator */
        .separator {
            border-top: 1px dashed #000;
            margin: 4px 0;
        }
        
        /* ====================================================
           REVISI UTAMA: STYLE TABEL HASIL PRODUKSI ROL (PORTRAIT)
           ==================================================== */
        .produksi-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 5px;
            font-size: 9pt;
        }
        
        .produksi-table th, 
        .produksi-table td {
            border: 1px solid #000;
            padding: 0; 
            text-align: center;
            vertical-align: middle;
        }
        
        .produksi-table th {
            font-weight: normal;
            font-size: 8.5pt;
            height: 18px;
        }
        
        /* Tinggi baris isi agar pas di A5 Portrait tanpa overflow ke lembar 2 */
        .produksi-table tbody td {
            height: 24px; 
        }
        
        /* Proporsi kolom format Portrait */
        .col-tgl { width: 8%; }
        .col-rol { width: 14%; }   /* Kolom untuk angka 1, 2, 3 */
        .col-tot-sis { width: 10%; } /* Kolom pecahan untuk Total dan Sisa */
        .col-prf { width: 8%; }
        
        /* TTD Area */
        .ttd-section {
            margin-top: 10px;
            width: 100%;
            font-size: 9pt;
        }
        
        /* Print button */
        .print-btn {
            display: block;
            text-align: center;
            margin-bottom: 10px;
        }
        
        .btn-print {
            background: #007bff;
            color: white;
            border: none;
            padding: 6px 15px;
            cursor: pointer;
            font-size: 11pt;
            border-radius: 5px;
        }
        
        @media print {
            .print-btn {
                display: none;
            }
            body {
                padding: 0;
                margin: 0;
            }
        }
    </style>
</head>
<body>

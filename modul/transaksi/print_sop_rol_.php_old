                        <tr><td class="label">Berat/Rol</td><td class="titik">:</td><td class="val"><?= number_format($detail['berat_rol'] ?: 0, 2) ?> KG/ROLL</td></tr>
                        <tr><td class="label">Isi/Bal</td><td class="titik">:</td><td class="val"><?= htmlspecialchars($detail['isi_bal_rol'] ?: '-') ?></td></tr>
                        <tr><td class="label">Jumlah Order</td><td class="titik">:</td><td class="val"><?= number_format($detail['jml_order_rol'] ?: 0, 0) ?> ROLL</td></tr>
